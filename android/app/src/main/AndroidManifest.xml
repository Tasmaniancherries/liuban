                    android:pathPrefix="/register" />
                <data
                    android:scheme="https"
                    android:host="www.liuban.app"
                    android:pathPrefix="/login" />
                <data
                    android:scheme="https"
                    android:host="www.liuban.app"
                    android:pathPrefix="/settings" />
                <data
                    android:scheme="https"
